# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret key for signing authentication tokens.
# Use a long random string in production.
JWT_SECRET="change-me-to-a-random-secret-in-production"

# LECTURER_DEFAULT_PASSWORD: Default password for the seeded lecturer account (username: admin).
# Change this immediately after first login.
LECTURER_DEFAULT_PASSWORD="admin123"

# GROQ_API_KEY: API key for the AI chatbot assistant (Groq / Llama 4).
# This key is now used SERVER-SIDE ONLY (never in the frontend bundle).
GROQ_API_KEY="your-groq-api-key"

# PHOTO_ENCRYPTION_KEY: AES-256 key for encrypting student photos at rest.
# Generate with: openssl rand -hex 32
PHOTO_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# ALLOWED_ORIGIN: Frontend origin for CORS.
ALLOWED_ORIGIN="http://localhost:3000"
